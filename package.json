{
  "name": "gaming-gauntlet-ui-kit",
  "private": true,
  "version": "0.1.0",
  "description": "Reusable Gaming Gauntlet UI kit extracted from the retired app.",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/web",
    "packages/ui"
  ],
  "scripts": {
    "build": "npm run build --workspace @gaming-gauntlet/ui && npm run build --workspace @gaming-gauntlet/web",
    "dev": "npm run dev --workspace @gaming-gauntlet/web",
    "lint": "eslint . --max-warnings=0",
    "test": "npm run test --workspace @gaming-gauntlet/web",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json --pretty false",
    "format": "prettier --write .",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.2"
  }
}
