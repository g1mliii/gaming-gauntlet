{
  "name": "gaming-gauntlet-twitch",
  "private": true,
  "version": "0.1.0",
  "description": "Gaming Gauntlet is a Twitch-integrated, multi-streamer challenge board for live game suggestions, voting, overlays, and score tracking.",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,extension,edge -c magenta,cyan,yellow \"npm:dev:web\" \"npm:dev:extension\" \"npm:dev:edge\"",
    "dev:web": "npm run dev --workspace @gaming-gauntlet/web",
    "dev:extension": "npm run dev --workspace @gaming-gauntlet/extension",
    "dev:edge": "npm run dev --workspace @gaming-gauntlet/edge",
    "build": "npm run build --workspace @gaming-gauntlet/web && npm run build --workspace @gaming-gauntlet/extension && npm run build --workspace @gaming-gauntlet/edge",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "verify": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.52.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.1.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4",
    "wrangler": "^4.10.0"
  }
}
