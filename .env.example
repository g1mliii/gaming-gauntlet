# Shared web origins
APP_ORIGIN=http://localhost:5173
EXTENSION_ORIGIN=http://localhost:5174

# Twitch application
TWITCH_CLIENT_ID=replace-me
TWITCH_CLIENT_SECRET=replace-me
TWITCH_REDIRECT_URI=http://localhost:8787/api/auth/twitch/callback
TWITCH_EVENTSUB_SECRET=replace-me
TWITCH_BOT_ACCESS_TOKEN=replace-me
TWITCH_BOT_REFRESH_TOKEN=replace-me
TWITCH_EXTENSION_CLIENT_ID=replace-me
TWITCH_EXTENSION_SECRET=replace-me

# Cloudflare / Worker runtime
CLOUDFLARE_ACCOUNT_ID=replace-me
CLOUDFLARE_API_TOKEN=replace-me
D1_DATABASE_ID=replace-me
QUEUE_NAME=gaming-gauntlet-event-ingest

# Session and signing secrets
SESSION_SECRET=replace-me-with-a-long-random-string
TOKEN_ENCRYPTION_KEY=replace-me-with-a-32-byte-base64-key
INTERNAL_API_KEY=replace-me
